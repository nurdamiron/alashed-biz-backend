# ======================
# SERVER
# ======================
PORT=3000
NODE_ENV=development

# ======================
# DATABASE (AWS RDS)
# ======================
DATABASE_URL=postgresql://user:password@host:5432/dbname
# Or individual vars:
DB_HOST=your-rds-endpoint.eu-north-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=alashed_business
DB_USER=postgres
DB_PASSWORD=your-password
DB_SSL=true

# ======================
# AUTHENTICATION
# ======================
JWT_SECRET=your-256-bit-secret-key-here
JWT_REFRESH_SECRET=your-refresh-256-bit-secret
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ======================
# CORS
# ======================
FRONTEND_URL=https://alashed-biz-frontend.vercel.app
ALLOWED_ORIGINS=https://alashed-biz-frontend.vercel.app,http://localhost:5173

# ======================
# AWS S3
# ======================
AWS_REGION=eu-north-1
AWS_S3_BUCKET=alashed-media
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ======================
# AI (Gemini)
# ======================
GEMINI_API_KEY=

# ======================
# WEBKASSA (Фискализация РК)
# ======================
WEBKASSA_API_URL=https://devkkm.webkassa.kz/api
WEBKASSA_TOKEN=your_webkassa_token
WEBKASSA_CASHBOX_ID=your_cashbox_id
WEBKASSA_TEST_MODE=true
