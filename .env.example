# Database
DATABASE_URL=postgresql://user:password@host:5432/database
DB_SSL=true

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Server
PORT=3000
NODE_ENV=development

# AI (Gemini)
GEMINI_API_KEY=your-gemini-api-key

# Webkassa (Fiscal)
WEBKASSA_URL=https://devkkm.webkassa.kz
WEBKASSA_LOGIN=your-login
WEBKASSA_PASSWORD=your-password
